# acu-template: observability.env — version 2026.04.16.1
# Langfuse configuration for OTel trace emission
# Generated by /acu-new. Do not commit — contains secrets.
#
# Traces are emitted by advance.sh after gate transitions when observability: true
# in the pipeline's CLAUDE.md frontmatter. Emission is best-effort and async —
# if Langfuse is unavailable, gates continue normally.
#
# To switch deployment modes, uncomment ONE LANGFUSE_HOST below and comment
# out the others. Keys come from Settings > API Keys in your Langfuse instance.

# Self-hosted (default — matches `docker-compose up` from the Langfuse repo)
LANGFUSE_HOST="http://localhost:3000"

# Cloud — uncomment ONE of the following and comment out the self-hosted line above
# LANGFUSE_HOST="https://us.cloud.langfuse.com"   # US region
# LANGFUSE_HOST="https://cloud.langfuse.com"      # EU region

LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""

# Optional: override base URL if different from host
# LANGFUSE_BASEURL="http://localhost:3000"
