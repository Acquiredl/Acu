initiative:
  id: "frontmatter-slim-down"
  name: "Progressive Frontmatter — Off-By-Default Fields Absent from Templates"
  status: "complete"
  current_stage: "validate"
  current_phase: "1"
  created: "2026-04-17"
  updated: "2026-04-17T00:31:41Z"

stages:
