  nomenclature-audit:
    name: "Evaluate every user-facing name in Acu (Sauron, Acu, gate, pipeline, stage, unit, etc.) against a beginner's mental model; classify as load-bearing metaphor, decorative metaphor, or cultural tax"
    pillar: "learning-friction-methodology"
    phase: 1
